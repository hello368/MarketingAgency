# ─────────────────────────────────────────
# Agency Remote Tracking System — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.
# ─────────────────────────────────────────

# Google Service Account credentials JSON file path
GOOGLE_CREDENTIALS_PATH=./credentials/service_account.json

# Google Sheets Master Dashboard ID
# Get this from the spreadsheet URL:
# https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
SPREADSHEET_ID=your_spreadsheet_id_here

# Daily Report Channel Google Chat Space ID
# Format: spaces/XXXXXXXXXXXXXXX
# Get this from the Space URL or first webhook event log
DAILY_REPORT_SPACE_ID=spaces/XXXXXXXXXXXXXXX

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# SQLite database path (auto-created)
DB_PATH=./data/tracking.db
